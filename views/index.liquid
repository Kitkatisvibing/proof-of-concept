{% render 'partials/head.liquid' %}
<main>
  <ul>
    {% for item in pokemon %}
      <li>
        <img src="{{ item.image }}" alt="{{ item.name }}" width="100" height="100" loading="lazy">
        <a href="/pokemon/{{ item.id }}"><p>{{ item.name }}</p></a>
      </li>
    {% endfor %}
  </ul>
</main>
{% render 'partials/foot.liquid' %}