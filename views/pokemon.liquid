{% render 'partials/head.liquid'%}
<a href="/">Back</a>
</header>

<main>       
    <img src="{{ pokemon.image }}" alt="{{ pokemon.name }}">
    <h1>{{ pokemon.name | capitalize }}</h1>

    <p>Pokedex number {{ pokemon.id }}</p>

    <ul class="info">
        <li>Height: {{ pokemon.height }} m</li>
        <li>Weight: {{ pokemon.weight }} kg</li>
        <li>Color: {{ pokemon.color }}</li>
    </ul>

    <h2>Type(s):</h2>

    <ul class="types">
        {% for type in pokemon.types %}
            <li class="{{ type | downcase }}">{{ type }}</li>
        {% endfor %}
    </ul>
</main>

{% if pokemon.color == "red" %}
    <style>
        main {
            background-color: var(--pokemon-red);
        }
    </style>
{% elsif pokemon.color == "blue" %}
    <style>
